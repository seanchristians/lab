{
	"tagOwners": {
		"tag:home": ["autogroup:admin"],
		"tag:infrastructure": ["autogroup:admin"],
		"tag:ci": ["autogroup:admin"]
	},

	"grants": [
		{
			"src": ["autogroup:admin"],
			"dst": ["autogroup:tagged", "svc:wg-easy"],
			"ip": ["*"]
		},
		{
			"src": ["tag:ci"],
			"dst": ["autogroup:tagged"],
			"ip": ["22"]
		}
	],

	"ssh": [
		{
			"action": "accept",
			"src": ["autogroup:admin"],
			"dst": ["autogroup:tagged"],
			"users": ["root", "autogroup:nonroot"]
		},
		{
			"action": "accept",
			"src": ["tag:ci"],
			"dst": ["autogroup:tagged"],
			"users": ["autogroup:nonroot"]
		},
		{
			"action": "accept",
			"src": ["tag:ci"],
			"dst": ["tag:infrastructure"],
			"users": ["root", "autogroup:nonroot"]
		}
	],

	"sshTests": [
		{
			"src": "tag:ci",
			"dst": ["tag:home"],
			"accept": ["certmgr"],
			"deny": ["root"]
		},
		{
			"src": "tag:home",
			"dst": ["tag:infrastructure"],
			"deny": ["root", "ubuntu", "ec2-user"]
		}
	],

	"autoApprovers": {
		"services": {
			"svc:wg-easy": ["tag:infrastructure"]
		}
	}
}

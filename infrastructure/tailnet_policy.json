{
	"tagOwners": {
		"tag:home": ["autogroup:admin"],
		"tag:infrastructure": ["autogroup:admin"],
		"tag:ci": ["autogroup:admin"],
		"tag:minecraft_servers": []
	},

	"grants": [
		{
			"src": ["autogroup:admin"],
			"dst": ["autogroup:tagged"],
			"ip": ["*"]
		},
		{
			"src": ["tag:ci"],
			"dst": ["autogroup:tagged"],
			"ip": ["22"]
		}
	],

	"ssh": [
		{
			"action": "accept",
			"src": ["autogroup:admin"],
			"dst": ["autogroup:tagged"],
			"users": ["root", "autogroup:nonroot"]
		},
		{
			"action": "accept",
			"src": ["tag:ci"],
			"dst": ["autogroup:tagged"],
			"users": ["autogroup:nonroot"]
		},
		{
			"action": "accept",
			"src": ["tag:ci"],
			"dst": ["tag:infrastructure"],
			"users": ["root", "autogroup:nonroot"]
		}
	],

	"sshTests": [
		{
			"src": "tag:ci",
			"dst": ["tag:home"],
			"accept": ["certmgr"],
			"deny": ["root"]
		},
		{
			"src": "tag:home",
			"dst": ["tag:infrastructure"],
			"deny": ["root", "ubuntu", "ec2-user"]
		}
	]
}
